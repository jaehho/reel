{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reel",
  "version": "0.1.0",
  "identifier": "dev.jaeho.reel",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "reel",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 520,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
